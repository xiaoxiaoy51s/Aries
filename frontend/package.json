{
  "name": "aries-desktop",
  "version": "1.0.0",
  "description": "Aries — 本地 AI 编程助手桌面应用",
  "author": "xiaoxiaoy51s",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xiaoxiaoy51s/Aries.git"
  },
  "homepage": "https://github.com/xiaoxiaoy51s/Aries#readme",
  "bugs": {
    "url": "https://github.com/xiaoxiaoy51s/Aries/issues"
  },
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/noto-sans-sc": "^5.2.9",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "dompurify": "^3.4.11",
    "github-markdown-css": "^5.9.0",
    "highlight.js": "^11.11.1",
    "katex": "^0.17.0",
    "markdown-it": "^14.2.0",
    "monaco-editor": "^0.55.1",
    "pinia": "^2.1.7",
    "vscode-icons-js": "^11.6.1",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.aries.desktop",
    "productName": "Aries",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/aries_backend.exe",
        "to": "aries_backend.exe"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false,
      "artifactName": "Aries-Setup-${version}.${ext}",
      "installerIcon": "public/logo.ico",
      "uninstallerIcon": "public/logo.ico"
    },
    "win": {
      "icon": "public/logo.png",
      "target": [
        "nsis",
        "7z"
      ],
      "sign": "./no-sign.js"
    },
    "mac": {
      "icon": "public/logo.png"
    },
    "linux": {
      "icon": "public/logo.png"
    },
    "publish": {
      "provider": "github",
      "owner": "xiaoxiaoy51s",
      "repo": "Aries"
    }
  }
}
