{
  "name": "mimoclaw-desktop",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder"
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^5.5.0",
    "katex": "^0.17.0",
    "pinia": "^2.1.7",
    "vue": "^3.4.0",
    "vue-router": "^4.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.0",
    "concurrently": "^9.2.1",
    "electron": "^33.4.11",
    "electron-builder": "^24.13.3",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^8.0.5"
  },
  "build": {
    "appId": "com.mimoclaw.desktop",
    "productName": "MIMOClaw",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "resources/mimo_backend.exe",
        "to": "mimo_backend.exe"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "public/favicon.ico",
      "uninstallerIcon": "public/favicon.ico"
    },
    "win": {
      "icon": "public/favicon.png",
      "target": ["nsis", "7z"],
      "sign": "./no-sign.js"
    },
    "mac": {
      "icon": "public/favicon.png"
    },
    "linux": {
      "icon": "public/favicon.png"
    }
  }
}
